# ============================================
# Worx GPS Recorder - Umgebungsvariablen
# Kopiere diese Datei als .env und passe die Werte an.
# ============================================

# MQTT-Konfiguration (Home Assistant Broker)
MQTT_HOST=homeassistant
MQTT_PORT=1883
MQTT_USER=dein_user
MQTT_PASSWORD=dein_passwort
MQTT_TOPIC_GPS=worx/gps
MQTT_TOPIC_STATUS=worx/status
MQTT_TOPIC_CONTROL=worx/control
MQTT_TOPIC_LOGS=worx/logs
MQTT_TOPIC_PI_STATUS=worx/pi/temperature
PI_STATUS_INTERVAL=30

# MQTT-Konfiguration (Lokaler Testbroker, optional)
MQTT_HOST_LOKAL=localhost
MQTT_PORT_LOKAL=1883
MQTT_USER_LOCAL=dein_user
MQTT_PASSWORD_LOCAL=dein_passwort

# AssistNow (nicht mehr aktiv, AOP läuft on-chip)
ASSIST_NOW_TOKEN=
ASSIST_NOW_ENABLED=False

# Serielle Konfiguration (nur für Raspberry Pi)
GPS_SERIAL_PORT=/dev/ttyACM0
GPS_BAUDRATE=9600

# Test-Modus (TRUE = Fake GPS, FALSE = echtes GPS)
TEST_MODE=FALSE

# Flask WebUI
FLASK_PORT=5001
FLASK_DEBUG=False

# Debug-Logging (TRUE für ausführliche Logs)
DEBUG_LOGGING=False
